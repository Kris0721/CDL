# Environment Variables Example

# JWT Secret Key (REQUIRED - Change this!)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# AWS SES Configuration
SES_FROM_EMAIL=noreply@defi-lending.com

# DynamoDB Table Names (Auto-generated by SAM, but can override)
USERS_TABLE=DeFi-Users
LOANS_TABLE=DeFi-Loans
TRANSACTIONS_TABLE=DeFi-Transactions
KYC_DOCUMENTS_TABLE=DeFi-KYCDocuments

# S3 Bucket for KYC Documents
KYC_BUCKET=defi-lending-kyc-documents

# Blockchain Configuration (Optional)
BLOCKCHAIN_RPC_URL=http://localhost:8545
LENDING_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# AWS Region
AWS_REGION=us-east-1
