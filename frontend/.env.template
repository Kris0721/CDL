# Frontend Environment Configuration for Sepolia Testnet
# IMPORTANT: Never commit this file to git!

# API URL - Update with your backend API endpoint
# For local development, use localhost
# For production, use your deployed API Gateway URL
VITE_API_URL=http://localhost:3001

# Sepolia Testnet Configuration
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Smart Contract Addresses
# Replace these with your deployed contract addresses from blockchain/deployments.json
VITE_LENDING_POOL_ADDRESS=
VITE_LOAN_MANAGER_ADDRESS=
VITE_INTEREST_CALCULATOR_ADDRESS=
VITE_TOKEN_ADDRESS=

# AWS Configuration (Optional - only if using AWS backend)
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_S3_BUCKET=

# Instructions:
# 1. Get a free RPC URL from Infura (https://infura.io) or Alchemy (https://alchemy.com)
# 2. Deploy contracts to Sepolia using: cd blockchain && npx hardhat run scripts/deploy.js --network sepolia
# 3. Copy the deployed contract addresses from blockchain/deployments.json
# 4. Paste the addresses above
# 5. Start the frontend: npm run dev
